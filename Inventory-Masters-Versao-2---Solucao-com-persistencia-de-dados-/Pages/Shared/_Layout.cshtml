@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    var nome = HttpContextAccessor.HttpContext.Session.GetString("NomeUsuario") ?? "Usuário";
    var email = HttpContextAccessor.HttpContext.Session.GetString("EmailUsuario") ?? "email@exemplo.com";
    var foto = HttpContextAccessor.HttpContext.Session.GetString("FotoPerfil") ?? "/images/profile.jpg";
    var paginaAtual = Context.Request.Path.Value ?? "";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - InventoryMaster</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        /* Estilo para o menu ativo com cor verde #228B22 */
        .nav-link.active {
            background-color: #228B22;
            color: white !important;
            font-weight: bold;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <aside class="sidebar d-flex flex-column justify-content-between" style="height: 100vh; padding: 1rem; width: 220px; background-color: #f8f9fa;">
        <div>
            <h5 class="px-3 mb-3">
                <img src="/Logo_inventory.png" alt="Logo InventoryMaster" class="rounded-circle me-2" style="width: 35px; height: 35px; object-fit: cover;" />
                InventoryMaster
            </h5>

            <div class="d-flex flex-column align-items-center mb-4 px-3">
                <img src="@foto" alt="Foto do Perfil" class="rounded-circle mb-2" style="width: 50px; height: 50px; object-fit: cover;" />
                <strong>@nome</strong>
                <small class="text-muted">@email</small>
            </div>

            <nav class="nav flex-column">
                <nav class="nav flex-column">
                    <a class="nav-link text-center @(paginaAtual.StartsWith("/Inicial") ? "active" : "")" asp-page="/Inicial">
                        <i class="bi bi-house me-2"></i> Inicial
                    </a>
                    <a class="nav-link text-center @(paginaAtual.StartsWith("/Estoque") ? "active" : "")" asp-page="/Estoque">
                        <i class="bi bi-box-seam me-2"></i> Estoque
                    </a>
                    <a class="nav-link text-center @(paginaAtual.StartsWith("/Parceiros") ? "active" : "")" asp-page="/Parceiros">
                        <i class="bi bi-people-fill me-2"></i> Parceiros
                    </a>
                    <a class="nav-link text-center @(paginaAtual.StartsWith("/Ajuda") ? "active" : "")" asp-page="/Ajuda">
                        <i class="bi bi-info-circle-fill me-2"></i> Ajuda
                    </a>
                </nav>
            </nav>
        </div>

        <div>
            <form method="get" asp-page="/Logout" style="width: 100%;">
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </button>
            </form>
        </div>
    </aside>

    <div class="main-content" style="margin-left: 220px; padding: 1rem;">
        <main role="main">
            @RenderBody()
        </main>

        <footer class="footer text-muted mt-4">
            <div class="container">
                &copy; 2025 - InventoryMaster - <a asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/residuosHub")
        .build();

    connection.on("ReceberVolume", function (volume) {
        document.getElementById("volumeDisplay").innerText = volume.toFixed(3) + " m³";
    });

    connection.start().catch(err => console.error(err));
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
