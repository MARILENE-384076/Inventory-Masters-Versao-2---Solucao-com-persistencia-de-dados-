<Window x:Class="AppInterfaceKinectUnificado.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=" Inventory Masters - Scanner de Volume " Height="680" Width="900"
        Background="#0A0A0A" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="10" Background="#111" CornerRadius="10" BorderBrush="#33FF66" BorderThickness="2">
            <StackPanel>
                <Image x:Name="CameraImage" Stretch="Uniform" Margin="5" />
                <TextBlock Text="Inventory Masters" Foreground="#33FF66" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="Soluções Inteligentes em Gestão de Estoque" Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="10" Background="#222" Padding="20" CornerRadius="10" BorderBrush="#33FF66" BorderThickness="2">
            <StackPanel VerticalAlignment="Top">

                <TextBlock Text="  Scanner de Volume  "  
                           Foreground="#33FF66"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0 0 0 20" />

                <Button x:Name="CalibrarChaoButton"
                        Content="Calibrar Chão"
                        Click="CalibrarChao_Click"
                        Background="#33AA33"
                        Foreground="White"
                        FontSize="18"
                        Padding="10"
                        Margin="0 0 0 15"
                        BorderThickness="0"/>

                <Button x:Name="ToggleKinectButton"
                        Content="Desligar"
                        Click="ToggleKinect_Click"
                        Background="#33AA33"
                        Foreground="White"
                        FontSize="18"
                        Padding="10"
                        Margin="0 0 0 25"
                        BorderThickness="0"/>

                <TextBlock x:Name="VolumeTextBlock"
                           Text="Volume: 0 cm³"
                           Foreground="#33FF66"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0 0 0 20"/>

                <TextBlock x:Name="StatusTextBlock"
                           Text="Aguardando inicialização..."
                           Foreground="White"
                           FontSize="16"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>